@app.route("/api/admin/support-ticket/reply", methods=["POST"])
def admin_reply_support_ticket():
    data = request.json or {}
    try:
        ticket_id = data.get("ticket_id")
        customer_id = data.get("customer_id")
        subject = (data.get("subject") or "Support Reply").strip()
        message = (data.get("message") or "").strip()
        close_ticket = bool(data.get("close_ticket", True))

        if not ticket_id or not customer_id or not message:
            return jsonify({"success": False, "error": "ticket_id, customer_id, and message are required"}), 400

        supabase.table("customer_messages").insert({
            "customer_id": customer_id,
            "subject": subject,
            "message": message,
            "sender_role": "ADMIN",
            "is_read": False
        }).execute()

        if close_ticket:
            supabase.table("support_tickets").update({
                "status": "CLOSED",
                "updated_at": datetime.utcnow().isoformat()
            }).eq("id", ticket_id).execute()

        return jsonify({"success": True})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 500

