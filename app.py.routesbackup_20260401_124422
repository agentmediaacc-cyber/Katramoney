@app.route("/admin")
def admin_dashboard():
    session["logged_in"] = True 
    try:
                # 1. Fetch all required tables
        apps_res = supabase.table("applications").select("*").execute()
        apps = apps_res.data if apps_res else []

        prods_res = supabase.table("loan_products").select("*").execute()
        prods_raw = prods_res.data if prods_res else []

        msgs_res = supabase.table("contacts").select("*").execute()
        msgs = msgs_res.data if msgs_res else []

        profiles_res = supabase.table("profiles").select("*").execute()
        profiles = profiles_res.data if profiles_res else []

        blacklist_res = supabase.table("blacklist").select("*").execute()
        blacklist = blacklist_res.data if blacklist_res else []

        support_res = supabase.table("support_tickets").select("*").execute()
        support_tickets = support_res.data if support_res else []

        cust_msg_res = supabase.table("customer_messages").select("*").execute()
        customer_messages = cust_msg_res.data if cust_msg_res else []

        payproof_res = supabase.table("loan_payments").select("*").execute()
        loan_payments = payproof_res.data if payproof_res else []

        # Fetch configurations safely
        conf_res = supabase.table("site_config").select("*").limit(1).execute()
        conf = conf_res.data[0] if conf_res and conf_res.data else {}
        
        settings_res = supabase.table("site_settings").select("*").limit(1).execute()
        settings = settings_res.data[0] if settings_res and settings_res.data else {}

        # 2. Clean data for Jinja2
        prods = []
        for p in prods_raw:
            p['terms'] = p.get('terms') if isinstance(p.get('terms'), list) else []
            p['interest_rate'] = to_float(p.get('interest_rate'), 0)
            p['service_fee'] = to_float(p.get('service_fee'), 0)
            p['min_amount'] = to_float(p.get('min_amount'), 0)
            p['max_amount'] = to_float(p.get('max_amount'), 0)
            p['active'] = to_bool(p.get('active'), True)
            prods.append(p)

        # 3. Calculate metrics
        total_val = sum(float(a.get('amount', 0)) for a in apps if a.get('amount'))
        pending = len([a for a in apps if str(a.get('status')).upper() == 'PENDING'])
        approved = len([a for a in apps if str(a.get('status')).upper() == 'APPROVED'])

        # 4. Render template with ALL required variables
        return render_template("admin.html",
                               apps=apps,
                               loan_products=prods,
                               contacts=msgs,
                               support_tickets=support_tickets,
                               customer_messages=customer_messages,
                               loan_payments=loan_payments, 
                               site_config=conf,
                               site_settings=settings,
                               profiles=profiles,
                               blacklist=blacklist,
                               total_val=total_val,
                               pending=pending,
                               approved=approved)
    except Exception as e:
        return f"Error Loading Dashboard: {e}"

