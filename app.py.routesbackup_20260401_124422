@app.route("/api/admin/profiles/<profile_id>/blacklist", methods=["POST"])
def blacklist_profile(profile_id):
    data = request.json or {}
    try:
        clean_id = profile_id
        profile_res = supabase.table("profiles").select("*").eq("id", clean_id).limit(1).execute()
        profile = profile_res.data[0] if profile_res and profile_res.data else None

        if not profile:
            return jsonify({"success": False, "error": "Profile not found"}), 404

        payload = {
            "blocked_id": clean_id,
            "blocked_phone": profile.get("phone"),
            "blocked_email": profile.get("email"),
            "reason": to_str(data.get("reason"), "Blocked by admin")
        }

        check = supabase.table("blacklist").select("*").eq("blocked_id", clean_id).limit(1).execute()
        if check and check.data:
            return jsonify({"success": True, "data": check.data, "message": "Already blacklisted"})

        res = supabase.table("blacklist").insert(payload).execute()
        return jsonify({"success": True, "data": res.data if res else []})
    except Exception as e:
        print("PROFILE BLACKLIST ERROR:", str(e))
        return jsonify({"success": False, "error": str(e)}), 500


