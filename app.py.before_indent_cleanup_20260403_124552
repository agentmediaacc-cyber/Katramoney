def to_int(value, default=0):
    try:
        if value is None or value == "":
            return int(default)
        return int(float(value))
    except Exception:
        return int(default)

def to_float(value, default=0.0):
    try:
        if value is None or value == "":
            return float(default)
        return float(value)
    except Exception:
        return float(default)

def to_bool(value, default=False):
    if isinstance(value, bool):
        return value
    if value is None:
        return default
    return str(value).strip().lower() in ["1", "true", "yes", "on"]

def to_str(value, default=""):
    if value is None:
        return default
    return str(value).strip()

def parse_csv_lines(value):
    raw = to_str(value, "")
    if not raw:
        return []
    parts = []
    for chunk in raw.replace(";", "\n").split("\n"):
        for item in chunk.split(","):
            item = item.strip()
            if item:
                parts.append(item)
    return parts

def admin_required(fn):
    @wraps(fn)
    def wrapper(*args, **kwargs):
        if not session.get("admin_logged_in"):
            if request.path.startswith("/api/"):
                return jsonify({"success": False, "error": "Unauthorized"}), 401
            return redirect(url_for("admin_login"))
        return fn(*args, **kwargs)
    return wrapper

def is_supabase_admin(user_id=None, email=None):
    try:
        if user_id:
            res = supabase_admin.table("admin_users").select("*").eq("user_id", user_id).limit(1).execute()
            if res and res.data:
                role = str((res.data[0].get("role") or "")).strip().lower()
                if role in ["", "admin", "super_admin", "superadmin"]:
                    return True

        if email:
            res = supabase_admin.table("admin_users").select("*").eq("email", email).limit(1).execute()
            if res and res.data:
                role = str((res.data[0].get("role") or "")).strip().lower()
                if role in ["", "admin", "super_admin", "superadmin"]:
                    return True

        return False
    except Exception as e:
        print("ADMIN CHECK EXCEPTION:", str(e))
        return False

def get_first_row(table_name):
    try:
        res = supabase_admin.table(table_name).select("*").limit(1).execute()
        if res and res.data:
            return res.data[0]
    except Exception as e:
        print(f"READ {table_name} ERROR:", e)
    return {}

def safe_table_rows(table_name, order_col=None, desc=False):
    try:
        query = supabase_admin.table(table_name).select("*")
        if order_col:
            query = query.order(order_col, desc=desc)
        res = query.execute()
        return res.data or []
    except Exception as e:
        print(f"READ TABLE {table_name} ERROR:", e)
        return []

