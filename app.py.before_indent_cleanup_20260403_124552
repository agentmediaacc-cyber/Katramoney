@app.route("/admin/login", methods=["GET", "POST"])
def admin_login():
    if request.method == "GET" and request.args.get("fresh") == "1":
        session.clear()

    if session.get("admin_logged_in") and request.method == "GET" and request.args.get("fresh") != "1":
        return redirect(url_for("admin_dashboard"))

    error = None

    if request.method == "POST":
        username = (request.form.get("username") or "").strip().lower()
        password = request.form.get("password") or ""

        if not username or not password:
            error = "Enter your admin email and password."
        else:
            try:
                headers = {
                    "apikey": SUPABASE_ANON,
                    "Content-Type": "application/json"
                }
                payload = {
                    "email": username,
                    "password": password
                }

                auth_res = requests.post(SUPABASE_AUTH_URL, headers=headers, json=payload, timeout=20)

                if not auth_res.ok:
                    error = "Invalid admin email or password."
                else:
                    auth_data = auth_res.json()
                    user = auth_data.get("user") or {}
                    user_id = user.get("id")
                    user_email = (user.get("email") or username).lower()

                    if is_supabase_admin(user_id, user_email):
                        session["admin_logged_in"] = True
                        session["admin_email"] = user_email
                        session["admin_user_id"] = user_id
                        session["admin_access_token"] = auth_data.get("access_token")
                        return redirect(url_for("admin_dashboard"))
                    else:
                        error = "This user is not registered as an admin."
            except Exception as e:
                error = f"Admin login failed: {str(e)}"

    # fallback inline page if admin_login.html does not exist
    login_template = os.path.join(BASE_DIR, "admin_login.html")
    if os.path.exists(login_template):
        return render_template("admin_login.html", error=error)

    return f"""
    <html>
    <head><title>Admin Login</title></head>
    <body style="font-family:Arial;padding:40px;">
      <h2>KATRAMONEY Admin Login</h2>
      <form method="post">
        <div style="margin-bottom:12px;"><input name="username" placeholder="Admin Email" style="padding:10px;width:300px;"></div>
        <div style="margin-bottom:12px;"><input name="password" type="password" placeholder="Password" style="padding:10px;width:300px;"></div>
        <button type="submit" style="padding:10px 16px;">Login</button>
      </form>
      <div style="color:red;margin-top:16px;">{error or ""}</div>
    </body>
    </html>
    """

@app.route("/api/admin/login", methods=["POST"])
def admin_login_api():
    data = request.json or {}
    username = (data.get("username") or "").strip().lower()
    password = data.get("password") or ""

    if not username or not password:
        return jsonify({"success": False, "error": "Username and password are required"}), 400

    try:
        headers = {
            "apikey": SUPABASE_ANON,
            "Content-Type": "application/json"
        }
        payload = {
            "email": username,
            "password": password
        }

        auth_res = requests.post(SUPABASE_AUTH_URL, headers=headers, json=payload, timeout=20)

        if not auth_res.ok:
            return jsonify({"success": False, "error": "Invalid admin email or password"}), 401

        auth_data = auth_res.json()
        user = auth_data.get("user") or {}
        user_id = user.get("id")
        user_email = (user.get("email") or username).lower()

        if not is_supabase_admin(user_id, user_email):
            return jsonify({"success": False, "error": "This user is not registered as an admin"}), 403

        session["admin_logged_in"] = True
        session["admin_email"] = user_email
        session["admin_user_id"] = user_id
        session["admin_access_token"] = auth_data.get("access_token")

        return jsonify({"success": True, "redirect": "/admin"})
    except Exception as e:
        return jsonify({"success": False, "error": str(e)}), 500

