<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KATRAMONEY - Advanced Admin Dashboard</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg: #0b1220;
      --panel: #111a2b;
      --card: #0f1726;
      --line: rgba(255,255,255,.08);
      --text: #e8eef8;
      --muted: #9fb0c7;
      --primary: #1d9bf0;
      --primary-2: #0ea5e9;
      --success: #12b76a;
      --warning: #f79009;
      --danger: #f04438;
      --white: #ffffff;
      --shadow: 0 20px 40px rgba(0,0,0,.28);
      --radius: 16px;
    }

    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      margin: 0;
      font-family: 'Inter', sans-serif;
      background: linear-gradient(180deg, #0b1220 0%, #09101b 100%);
      color: var(--text);
    }

    a { text-decoration: none; color: inherit; }
    button, input, select, textarea { font: inherit; }

    /* LAYOUT */
    .layout {
      display: grid;
      grid-template-columns: 260px 1fr;
      min-height: 100vh;
    }

    .sidebar {
      position: sticky;
      top: 0;
      height: 100vh;
      background: rgba(10,16,28,.95);
      border-right: 1px solid var(--line);
      padding: 24px 16px;
      overflow-y: auto;
      z-index: 40;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 30px;
    }

    .brand-badge {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
      color: white;
      font-size: 20px;
      font-weight: 900;
    }

    .brand h1 { margin: 0; font-size: 16px; line-height: 1.2; }
    .brand p { margin: 2px 0 0; color: var(--muted); font-size: 11px; }

    .nav-title {
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: .1em;
      color: var(--muted);
      margin: 24px 0 8px 10px;
      font-weight: 700;
    }

    .nav { display: flex; flex-direction: column; gap: 4px; }
    .nav a {
      padding: 12px 14px;
      border-radius: 12px;
      color: var(--muted);
      font-size: 14px;
      font-weight: 500;
      transition: .2s;
      display: flex;
      justify-content: space-between;
    }
    .nav a:hover, .nav a.active {
      background: rgba(29,155,240,.1);
      color: var(--text);
      font-weight: 600;
    }

    .main { padding: 24px; min-width: 0; }

    /* TOPBAR */
    .topbar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      background: rgba(17,26,43,.8);
      backdrop-filter: blur(10px);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 16px 20px;
      margin-bottom: 24px;
    }
    .topbar h2 { margin: 0; font-size: 20px; }
    .topbar p { margin: 4px 0 0; color: var(--muted); font-size: 13px; }

    /* CARDS & GRIDS */
    .stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 16px;
      margin-bottom: 24px;
    }
    .stat {
      background: linear-gradient(180deg, #162235, #0f1726);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 20px;
    }
    .stat small { color: var(--muted); font-size: 12px; font-weight: 600; text-transform: uppercase; }
    .stat .num { font-size: 28px; font-weight: 800; margin-top: 8px; }

    .section-view { display: none; animation: fadeIn 0.3s ease; }
    .section-view.active { display: block; }
    @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    .card {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 20px;
      margin-bottom: 24px;
    }
    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      flex-wrap: wrap;
      gap: 12px;
    }
    .card-header h3 { margin: 0; font-size: 18px; }

    /* FORMS */
    .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px; }
    .field label { display: block; margin-bottom: 6px; color: var(--muted); font-size: 12px; font-weight: 600; }
    input, select, textarea {
      width: 100%;
      padding: 12px 14px;
      border-radius: 10px;
      border: 1px solid var(--line);
      background: rgba(255,255,255,.03);
      color: var(--text);
      outline: none;
      transition: .2s;
    }
    input:focus, select:focus, textarea:focus { border-color: var(--primary); background: rgba(0,0,0,.2); }
    textarea { min-height: 90px; resize: vertical; }

    /* BUTTONS */
    .btn {
      border: none;
      background: linear-gradient(135deg, var(--primary), var(--primary-2));
      color: white;
      padding: 10px 18px;
      border-radius: 10px;
      cursor: pointer;
      font-weight: 600;
      font-size: 13px;
      display: inline-flex;
      align-items: center;
      gap: 8px;
    }
    .btn.secondary { background: rgba(255,255,255,.05); border: 1px solid var(--line); color: var(--text); }
    .btn.danger { background: var(--danger); }
    .btn.success { background: var(--success); }
    .btn.warning { background: var(--warning); }
    .btn-sm { padding: 6px 12px; font-size: 11px; border-radius: 6px; }

    /* TABLES */
    .table-wrap { overflow-x: auto; border: 1px solid var(--line); border-radius: 12px; }
    table { width: 100%; border-collapse: collapse; min-width: 800px; text-align: left; }
    th { background: #101a2b; padding: 14px; font-size: 12px; color: var(--muted); text-transform: uppercase; border-bottom: 1px solid var(--line); }
    td { padding: 14px; border-bottom: 1px solid var(--line); font-size: 14px; vertical-align: middle; }
    tr:hover td { background: rgba(255,255,255,.02); }

    .pill {
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      background: rgba(255,255,255,.1);
    }
    .pill.pending { color: #fdb022; background: rgba(247,144,9,.15); }
    .pill.approved { color: #32d583; background: rgba(18,183,106,.15); }
    .pill.rejected { color: #f97066; background: rgba(240,68,56,.15); }

    /* MODAL */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.7);
      backdrop-filter: blur(5px);
      z-index: 100;
      display: none;
      place-items: center;
      padding: 20px;
    }
    .modal {
      background: var(--card);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      width: 100%;
      max-width: 700px;
      max-height: 90vh;
      overflow-y: auto;
      box-shadow: var(--shadow);
    }
    .modal-head {
      padding: 20px;
      border-bottom: 1px solid var(--line);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .modal-body { padding: 20px; }
    .doc-card {
      background: rgba(255,255,255,.03);
      border: 1px solid var(--line);
      padding: 12px;
      border-radius: 8px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 10px;
    }
    
    .mobile-menu-btn { display: none; }

    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; }
      .sidebar { position: fixed; left: -100%; width: 260px; transition: .3s; }
      .sidebar.show { left: 0; }
      .mobile-menu-btn { display: block; }
    }
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar" id="sidebar">
      <div class="brand">
        <div class="brand-badge">K</div>
        <div>
          <h1>KATRAMONEY Admin</h1>
          <p>Superuser Dashboard</p>
        </div>
      </div>

      <div class="nav-title">Management</div>
      <div class="nav">
        <a href="#" onclick="switchTab('dashboard')" class="nav-link active" id="tab-dashboard">Dashboard <span>→</span></a>
        <a href="#" onclick="switchTab('applications')" class="nav-link" id="tab-applications">Applications <span>→</span></a>
        <a href="#" onclick="switchTab('users')" class="nav-link" id="tab-users">Users & Blacklist <span>→</span></a>
        <a href="#" onclick="switchTab('products')" class="nav-link" id="tab-products">Loan Products <span>→</span></a>
        <a href="#" onclick="switchTab('messages')" class="nav-link" id="tab-messages">Messages <span>→</span></a>
      </div>

      <div class="nav-title">Website Configuration</div>
      <div class="nav">
        <a href="#" onclick="switchTab('site-config')" class="nav-link" id="tab-site-config">Frontend Content <span>→</span></a>
        <a href="#" onclick="switchTab('site-settings')" class="nav-link" id="tab-site-settings">System Rates <span>→</span></a>
      </div>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h2 id="page-title">Dashboard Overview</h2>
          <p id="page-subtitle">Welcome back. Here is what is happening today.</p>
        </div>
        <div style="display:flex; gap:10px;">
          <button class="btn secondary mobile-menu-btn" onclick="toggleSidebar()">☰ Menu</button>
          <a class="btn secondary" href="/" target="_blank">View Live Site</a>
        </div>
      </div>

      <div id="view-dashboard" class="section-view active">
        <div class="stats">
          <div class="stat">
            <small>Total Applications</small>
            <div class="num">{{ apps|length }}</div>
          </div>
          <div class="stat">
            <small>Pending Reviews</small>
            <div class="num" style="color:var(--warning)">{{ pending or 0 }}</div>
          </div>
          <div class="stat">
            <small>Total Loan Requested</small>
            <div class="num">N$ {{ "%.2f"|format(total_val or 0) }}</div>
          </div>
          <div class="stat">
            <small>Unread Messages</small>
            <div class="num" style="color:var(--primary)">{{ contacts|length }}</div>
          </div>
        </div>
      </div>

      <div id="view-applications" class="section-view">
        <div class="card">
          <div class="card-header">
            <h3>Recent Loan Applications</h3>
            <input type="text" placeholder="Search by name, ref, email..." style="width:250px" onkeyup="filterTable('appTable', this.value)">
          </div>
          <div class="table-wrap">
            <table id="appTable">
              <thead>
                <tr>
                  <th>Ref</th>
                  <th>Applicant</th>
                  <th>Product</th>
                  <th>Amount & Term</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for a in apps %}
                <tr>
                  <td><strong>{{ a.reference }}</strong></td>
                  <td>
                    <div>{{ a.full_name }}</div>
                    <div style="font-size:12px; color:var(--muted)">{{ a.phone }}</div>
                  </td>
                  <td>{{ a.product_name }}</td>
                  <td>N$ {{ a.amount }}<br><small class="muted">{{ a.term }} months</small></td>
                  <td>
                    <span class="pill {% if a.status == 'APPROVED' %}approved{% elif a.status == 'REJECTED' %}rejected{% else %}pending{% endif %}">
                      {{ a.status or 'PENDING' }}
                    </span>
                  </td>
                  <td>{{ a.created_at.strftime('%Y-%m-%d') if a.created_at else '' }}</td>
                  <td>
                    <button class="btn btn-sm secondary" onclick="openAppModal('{{ a.id }}', '{{ a.reference }}', '{{ a.full_name }}', '{{ a.email }}', '{{ a.phone }}', '{{ a.amount }}', '{{ a.admin_note }}', '{{ a.status }}')">View & Manage</button>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="view-users" class="section-view">
        <div class="card">
          <div class="card-header">
            <h3>Registered Profiles</h3>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>ID</th>
                  <th>Full Name</th>
                  <th>Role</th>
                  <th>Joined Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for p in profiles %}
                <tr>
                  <td><small>{{ p.id }}</small></td>
                  <td>{{ p.full_name }}</td>
                  <td><span class="pill pending">{{ p.role }}</span></td>
                  <td>{{ p.created_at }}</td>
                  <td><button class="btn btn-sm warning" onclick="blockUser('{{ p.id }}')">Blacklist</button></td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <div class="card-header">
            <h3>Blacklisted Users</h3>
            <button class="btn btn-sm secondary" onclick="addToBlacklist()">+ Add Manual Entry</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>User ID / Target</th>
                  <th>Reason</th>
                  <th>Blocked Phone</th>
                  <th>Blocked Email</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for b in blacklist %}
                <tr>
                  <td>{{ b.blocked_id }}</td>
                  <td>{{ b.reason }}</td>
                  <td>{{ b.blocked_phone }}</td>
                  <td>{{ b.blocked_email }}</td>
                  <td><button class="btn btn-sm secondary" onclick="unblockUser('{{ b.id }}')">Remove</button></td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="view-products" class="section-view">
        <div class="card">
          <div class="card-header">
            <h3>Loan Products Catalog</h3>
            <button class="btn" onclick="openProductModal()">+ Create Product</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Product Name</th>
                  <th>Interest / Fee</th>
                  <th>Min/Max (N$)</th>
                  <th>Status</th>
                  <th>Actions</th>
                </tr>
              </thead>
              <tbody>
                {% for p in loan_products %}
                <tr>
                  <td>
                    <strong>{{ p.name }}</strong>
                    {% if p.featured %}<span class="pill approved" style="margin-left:8px">Featured</span>{% endif %}
                  </td>
                  <td>{{ p.interest_rate }}% / N$ {{ p.service_fee }}</td>
                  <td>{{ p.min_amount }} - {{ p.max_amount }}</td>
                  <td><span class="pill {% if p.active %}approved{% else %}rejected{% endif %}">{{ "Active" if p.active else "Disabled" }}</span></td>
                  <td>
                    <button class="btn btn-sm secondary" onclick="openEdit('{{ p.id }}', '{{ p.name }}', '{{ p.interest_rate }}', '{{ p.service_fee }}')">Edit</button>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="view-messages" class="section-view">
        <div class="card">
          <div class="card-header">
            <h3>Customer Support Messages</h3>
            <p style="margin:0; font-size:12px; color:var(--muted);">Messages received from the website chat/contact forms.</p>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Contact Details</th>
                  <th>Message Preview</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for c in contacts %}
                <tr>
                  <td><strong>{{ c.name }}</strong></td>
                  <td>{{ c.email }}<br><small>{{ c.phone }}</small></td>
                  <td style="max-width:300px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ c.message }}</td>
                  <td>{{ c.created_at }}</td>
                  <td>
                    <button class="btn btn-sm primary" onclick="openReplyModal('{{ c.email }}', '{{ c.name }}', `{{ c.message }}`)">Read & Reply</button>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div id="view-site-config" class="section-view">
        <div class="card">
          <div class="card-header">
            <h3>Frontend Content Settings</h3>
            <button class="btn success" onclick="saveForm('siteConfigForm', '/api/admin/site-config')">Save Changes</button>
          </div>
          <form id="siteConfigForm">
            <h4 style="margin-top:0; border-bottom:1px solid var(--line); padding-bottom:10px;">Branding & Hero</h4>
            <div class="form-grid">
              <div class="field"><label>Site Name</label><input name="site_name" value="{{ site_config.site_name }}"></div>
              <div class="field"><label>Promo Text (Topbar)</label><input name="promo_text" value="{{ site_config.promo_text }}"></div>
              <div class="field"><label>Hero Trust Text</label><input name="hero_trust_text" value="{{ site_config.hero_trust_text }}"></div>
              <div class="field"><label>Hero Title</label><input name="hero_title" value="{{ site_config.hero_title }}"></div>
            </div>
            <div class="field" style="margin-top:16px;">
              <label>Hero Subtitle</label>
              <textarea name="hero_subtitle">{{ site_config.hero_subtitle }}</textarea>
            </div>
            
            <div class="form-grid" style="margin-top:16px;">
              <div class="field"><label>Hero Chip 1</label><input name="hero_chip_1" value="{{ site_config.hero_chip_1 }}"></div>
              <div class="field"><label>Hero Chip 2</label><input name="hero_chip_2" value="{{ site_config.hero_chip_2 }}"></div>
              <div class="field"><label>Hero Chip 3</label><input name="hero_chip_3" value="{{ site_config.hero_chip_3 }}"></div>
            </div>

            <h4 style="border-bottom:1px solid var(--line); padding-bottom:10px; margin-top:30px;">Contact & Footer</h4>
            <div class="form-grid">
              <div class="field"><label>Support Phone</label><input name="support_phone" value="{{ site_config.support_phone }}"></div>
              <div class="field"><label>Contact Email</label><input name="email" value="{{ site_config.email }}"></div>
              <div class="field"><label>Office Hours</label><input name="office_hours" value="{{ site_config.office_hours }}"></div>
              <div class="field"><label>Address</label><input name="address" value="{{ site_config.address }}"></div>
            </div>
            
            <div class="form-grid" style="margin-top:16px;">
              <div class="field"><label>Contact Intro Text</label><textarea name="contact_intro">{{ site_config.contact_intro }}</textarea></div>
              <div class="field"><label>Footer Text</label><textarea name="footer_text">{{ site_config.footer_text }}</textarea></div>
              <div class="field"><label>Compliance Text</label><textarea name="compliance_text">{{ site_config.compliance_text }}</textarea></div>
              <div class="field"><label>Calculator Note</label><textarea name="calc_note">{{ site_config.calc_note }}</textarea></div>
            </div>

            <h4 style="border-bottom:1px solid var(--line); padding-bottom:10px; margin-top:30px;">Global Limits</h4>
            <div class="form-grid">
              <div class="field"><label>Global Min Loan</label><input type="number" name="min_loan" value="{{ site_config.min_loan }}"></div>
              <div class="field"><label>Global Max Loan</label><input type="number" name="max_loan" value="{{ site_config.max_loan }}"></div>
              <div class="field"><label>Approval Window</label><input name="approval_window" value="{{ site_config.approval_window }}"></div>
            </div>
          </form>
        </div>
      </div>

      <div id="view-site-settings" class="section-view">
        <div class="card">
          <div class="card-header">
            <h3>System Rates & Settings</h3>
            <button class="btn success" onclick="saveForm('siteSettingsForm', '/api/admin/site-settings')">Save Settings</button>
          </div>
          <form id="siteSettingsForm">
            <div class="form-grid">
              <div class="field"><label>Base Interest Rate (%)</label><input type="number" step="0.01" name="interest_rate" value="{{ site_settings.interest_rate }}"></div>
              <div class="field"><label>Base Service Fee (N$)</label><input type="number" step="0.01" name="service_fee" value="{{ site_settings.service_fee }}"></div>
              <div class="field"><label>Business Loan Rate (%)</label><input type="number" step="0.01" name="business_loan_rate" value="{{ site_settings.business_loan_rate }}"></div>
              <div class="field"><label>Personal Loan Rate (%)</label><input type="number" step="0.01" name="personal_loan_rate" value="{{ site_settings.personal_loan_rate }}"></div>
              <div class="field"><label>Salary Advance Rate (%)</label><input type="number" step="0.01" name="salary_advance_rate" value="{{ site_settings.salary_advance_rate }}"></div>
            </div>
          </form>
        </div>
      </div>

    </main>
  </div>

  <div class="modal-overlay" id="appModalOverlay">
    <div class="modal">
      <div class="modal-head">
        <h3 style="margin:0;">Application Details</h3>
        <button class="btn secondary btn-sm" onclick="closeModal('appModalOverlay')">Close</button>
      </div>
      <div class="modal-body">
        <div class="form-grid" style="margin-bottom: 20px;">
          <div>
            <strong style="color:var(--primary); font-size:12px; text-transform:uppercase;">Applicant Info</strong>
            <p id="app-name" style="margin:4px 0; font-size:18px; font-weight:700;"></p>
            <p id="app-contact" style="margin:0; font-size:14px; color:var(--muted);"></p>
          </div>
          <div>
            <strong style="color:var(--primary); font-size:12px; text-transform:uppercase;">Loan Info</strong>
            <p id="app-ref" style="margin:4px 0; font-size:14px; color:var(--muted);"></p>
            <p id="app-amount" style="margin:0; font-size:24px; font-weight:800;"></p>
          </div>
        </div>

        <div class="field">
          <label>Uploaded Documents (Fetched from Storage)</label>
          <div id="app-documents" style="background:rgba(0,0,0,.2); padding:10px; border-radius:10px; min-height:80px;">
            <p style="text-align:center; color:var(--muted); font-size:12px; margin-top:20px;">Loading user uploads...</p>
          </div>
        </div>

        <div class="field" style="margin-top:20px;">
          <label>Admin Note (Visible only to staff)</label>
          <textarea id="app-note" placeholder="Internal remarks regarding approval/rejection..."></textarea>
        </div>

        <div class="field" style="margin-top:16px;">
          <label>Decision / Status</label>
          <select id="app-status">
            <option value="PENDING">Pending Review</option>
            <option value="APPROVED">Approved</option>
            <option value="REJECTED">Rejected</option>
          </select>
        </div>

        <div style="margin-top:24px; display:flex; gap:12px;">
          <button class="btn success" onclick="updateApplication()">Save & Update Status</button>
          <button class="btn warning" onclick="alert('Sending email requirement...')">Request Missing Documents</button>
        </div>
      </div>
    </div>
  </div>

