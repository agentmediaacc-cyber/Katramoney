<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>KATRAMONEY Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#07111c;
      --bg2:#0c1726;
      --panel:rgba(10,18,31,.84);
      --panel2:rgba(15,27,45,.9);
      --card:rgba(255,255,255,.05);
      --line:rgba(255,255,255,.10);
      --text:#edf4ff;
      --muted:#9bb0ca;
      --primary:#49a8ff;
      --primary2:#76c3ff;
      --success:#17b26a;
      --warning:#f79009;
      --danger:#f04438;
      --radius:22px;
      --shadow:0 24px 60px rgba(0,0,0,.30);
    }

    *{box-sizing:border-box}
    html,body{margin:0;padding:0;font-family:Inter,sans-serif;color:var(--text);background:#08111b}
    body{
      min-height:100vh;
      background:
        linear-gradient(rgba(6,14,22,.72), rgba(6,14,22,.88)),
        radial-gradient(circle at top right, rgba(73,168,255,.16), transparent 26%),
        radial-gradient(circle at bottom left, rgba(118,195,255,.10), transparent 25%),
        url("https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=1600&q=80") center/cover fixed no-repeat;
    }

    a{text-decoration:none;color:inherit}
    button,input,select,textarea{font:inherit}
    .hidden{display:none!important}

    .shell{
      display:grid;
      grid-template-columns:285px 1fr;
      min-height:100vh;
      backdrop-filter: blur(3px);
    }

    .sidebar{
      position:sticky; top:0; height:100vh;
      background:linear-gradient(180deg, rgba(7,14,24,.95), rgba(9,18,31,.88));
      border-right:1px solid var(--line);
      padding:18px 14px;
      overflow-y:auto;
      z-index:20;
    }

    .brand{
      display:flex; align-items:center; gap:12px;
      padding:14px;
      border-radius:18px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
      margin-bottom:18px;
      box-shadow:var(--shadow);
    }
    .badge{
      width:50px; height:50px; border-radius:16px;
      display:grid; place-items:center;
      background:linear-gradient(135deg, #6bbcff, #2f8fff);
      color:#fff; font-size:22px; font-weight:900;
      box-shadow:0 10px 30px rgba(47,143,255,.30);
    }
    .brand h1{margin:0;font-size:16px}
    .brand p{margin:4px 0 0;font-size:12px;color:var(--muted)}

    .nav-title{
      margin:20px 10px 8px;
      color:var(--muted);
      font-size:11px;
      font-weight:800;
      letter-spacing:.12em;
      text-transform:uppercase;
    }

    .nav{
      display:flex;
      flex-direction:column;
      gap:8px;
    }

    .nav-btn{
      width:100%;
      text-align:left;
      border:none;
      border-radius:16px;
      padding:13px 14px;
      cursor:pointer;
      color:var(--muted);
      background:transparent;
      font-weight:700;
      display:flex;
      justify-content:space-between;
      align-items:center;
      transition:.2s ease;
    }
    .nav-btn:hover,.nav-btn.active{
      background:linear-gradient(180deg, rgba(73,168,255,.14), rgba(73,168,255,.08));
      color:var(--text);
      border:1px solid rgba(73,168,255,.18);
    }

    .main{
      padding:22px;
      min-width:0;
    }

    .topbar{
      display:flex; justify-content:space-between; align-items:center; gap:12px; flex-wrap:wrap;
      background:rgba(9,18,31,.62);
      border:1px solid var(--line);
      border-radius:24px;
      padding:18px 20px;
      box-shadow:var(--shadow);
      backdrop-filter: blur(16px);
      margin-bottom:20px;
    }
    .topbar h2{margin:0;font-size:25px}
    .topbar p{margin:6px 0 0;color:var(--muted);font-size:13px}

    .toolbar{display:flex;gap:10px;flex-wrap:wrap}

    .btn{
      border:none;
      border-radius:14px;
      padding:11px 16px;
      cursor:pointer;
      color:#fff;
      font-weight:800;
      background:linear-gradient(135deg,var(--primary),var(--primary2));
      box-shadow:0 10px 24px rgba(73,168,255,.18);
    }
    .btn.secondary{
      background:rgba(255,255,255,.05);
      border:1px solid var(--line);
      color:var(--text);
      box-shadow:none;
    }
    .btn.success{background:var(--success)}
    .btn.danger{background:var(--danger)}
    .btn.warn{background:var(--warning)}
    .btn.sm{padding:8px 12px;font-size:12px;border-radius:11px}

    .section{display:none;animation:fade .24s ease}
    .section.active{display:block}
    @keyframes fade{
      from{opacity:0;transform:translateY(8px)}
      to{opacity:1;transform:translateY(0)}
    }

    .stats{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:16px;
      margin-bottom:20px;
    }

    .stat{
      background:linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.04));
      border:1px solid var(--line);
      border-radius:22px;
      padding:20px;
      backdrop-filter:blur(12px);
      box-shadow:var(--shadow);
    }
    .stat small{
      display:block;
      font-size:12px;
      font-weight:800;
      color:var(--muted);
      text-transform:uppercase;
      letter-spacing:.08em;
      margin-bottom:8px;
    }
    .stat .num{
      font-size:30px;
      font-weight:900;
      line-height:1.1;
    }

    .grid2{
      display:grid;
      grid-template-columns:1.25fr .95fr;
      gap:18px;
    }

    .card{
      background:linear-gradient(180deg, rgba(255,255,255,.06), rgba(255,255,255,.035));
      border:1px solid var(--line);
      border-radius:24px;
      padding:18px;
      box-shadow:var(--shadow);
      backdrop-filter:blur(14px);
      margin-bottom:18px;
      min-width:0;
    }

    .card-head{
      display:flex; justify-content:space-between; align-items:center; gap:10px; flex-wrap:wrap;
      margin-bottom:15px;
    }
    .card-head h3{margin:0;font-size:18px}
    .muted{color:var(--muted)}
    .small{font-size:12px}

    .overview-list{display:grid;gap:12px}
    .overview-item{
      display:flex;justify-content:space-between;align-items:center;gap:12px;
      padding:14px 15px;
      border-radius:18px;
      background:rgba(255,255,255,.04);
      border:1px solid var(--line);
    }

    .form-grid{
      display:grid;
      grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
      gap:14px;
    }
    .field label{
      display:block;
      margin-bottom:6px;
      font-size:12px;
      font-weight:800;
      color:var(--muted);
    }
    input,select,textarea{
      width:100%;
      border-radius:14px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.05);
      color:var(--text);
      padding:12px 14px;
      outline:none;
    }
    textarea{min-height:110px;resize:vertical}
    input:focus,select:focus,textarea:focus{
      border-color:rgba(73,168,255,.55);
      background:rgba(255,255,255,.08);
    }

    .table-wrap{
      overflow:auto;
      border-radius:18px;
      border:1px solid var(--line);
      background:rgba(0,0,0,.08);
    }
    table{
      width:100%;
      min-width:920px;
      border-collapse:collapse;
    }
    th,td{
      padding:14px 12px;
      border-bottom:1px solid var(--line);
      text-align:left;
      vertical-align:middle;
      font-size:14px;
    }
    th{
      background:rgba(255,255,255,.04);
      color:var(--muted);
      font-size:12px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.06em;
    }
    tr:hover td{background:rgba(255,255,255,.03)}

    .pill{
      display:inline-flex;
      align-items:center;
      padding:6px 10px;
      border-radius:999px;
      font-size:11px;
      font-weight:900;
      background:rgba(255,255,255,.08);
    }
    .pending{color:#ffd26b;background:rgba(247,144,9,.16)}
    .approved{color:#86e2af;background:rgba(23,178,106,.16)}
    .rejected{color:#ffa6a0;background:rgba(240,68,56,.16)}
    .active-pill{color:#9dd4ff;background:rgba(73,168,255,.18)}

    .actions{
      display:flex;
      gap:8px;
      flex-wrap:wrap;
    }

    .modal-wrap{
      position:fixed;
      inset:0;
      display:none;
      align-items:center;
      justify-content:center;
      padding:16px;
      background:rgba(4,10,18,.72);
      backdrop-filter:blur(10px);
      z-index:90;
    }
    .modal-wrap.show{display:flex}
    .modal{
      width:100%;
      max-width:760px;
      max-height:90vh;
      overflow:auto;
      background:linear-gradient(180deg, rgba(12,24,40,.96), rgba(8,18,31,.96));
      border:1px solid var(--line);
      border-radius:24px;
      box-shadow:var(--shadow);
    }
    .modal-head,.modal-body{padding:18px}
    .modal-head{
      display:flex;
      justify-content:space-between;
      align-items:center;
      gap:10px;
      border-bottom:1px solid var(--line);
    }

    .mobile-toggle{display:none}

    @media (max-width: 980px){
      .shell{grid-template-columns:1fr}
      .sidebar{
        position:fixed;
        left:-110%;
        width:285px;
        transition:.25s ease;
      }
      .sidebar.show{left:0}
      .mobile-toggle{display:inline-flex}
      .main{padding:14px}
      .grid2{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <div class="shell">
    <aside class="sidebar" id="sidebar">
      <div class="brand">
        <div class="badge">K</div>
        <div>
          <h1>KATRAMONEY Admin</h1>
          <p>Premium Banking Control Portal</p>
        </div>
      </div>

      <div class="nav-title">Overview</div>
      <div class="nav">
        <button class="nav-btn active" data-section="overview">Dashboard <span>→</span></button>
      </div>

      <div class="nav-title">Operations</div>
      <div class="nav">
        <button class="nav-btn" data-section="applications">Applications <span>→</span></button>
        <button class="nav-btn" data-section="products">Loan Products <span>→</span></button>
        <button class="nav-btn" data-section="messages">Messages <span>→</span></button>
      </div>

      <div class="nav-title">Website</div>
      <div class="nav">
        <button class="nav-btn" data-section="site-config">Frontend Content <span>→</span></button>
        <button class="nav-btn" data-section="site-settings">System Rates <span>→</span></button>
      </div>

      <div class="nav-title">Session</div>
      <div class="nav">
        <a class="nav-btn" href="/" target="_blank">View Live Site <span>↗</span></a>
        <a class="nav-btn" href="/admin/logout">Logout <span>↗</span></a>
      </div>
    </aside>

    <main class="main">
      <div class="topbar">
        <div>
          <h2 id="pageTitle">Dashboard Overview</h2>
          <p id="pageSubtitle">Premium loan operations and platform controls.</p>
        </div>
        <div class="toolbar">
          <button class="btn secondary mobile-toggle" type="button" onclick="toggleSidebar()">☰ Menu</button>
          <button class="btn secondary" type="button" onclick="window.location.reload()">Refresh</button>
          <button class="btn" type="button" onclick="openProductModal()">+ New Product</button>
        </div>
      </div>

      <section class="section active" id="section-overview">
        <div class="stats">
          <div class="stat">
            <small>Total Applications</small>
            <div class="num">{{ apps|length if apps is defined else 0 }}</div>
          </div>
          <div class="stat">
            <small>Pending Reviews</small>
            <div class="num">{{ pending or 0 }}</div>
          </div>
          <div class="stat">
            <small>Loan Products</small>
            <div class="num">{{ loan_products|length if loan_products is defined else 0 }}</div>
          </div>
          <div class="stat">
            <small>Total Requested</small>
            <div class="num">N$ {{ "%.2f"|format(total_val or 0) }}</div>
          </div>
        </div>

        <div class="grid2">
          <div>
            <div class="card">
              <div class="card-head">
                <h3>Recent Applications</h3>
                <span class="muted small">Latest customer requests</span>
              </div>
              <div class="table-wrap">
                <table>
                  <thead>
                    <tr>
                      <th>Ref</th>
                      <th>Applicant</th>
                      <th>Product</th>
                      <th>Amount</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody>
                    {% for a in apps[:8] %}
                    <tr>
                      <td><strong>{{ a.reference }}</strong></td>
                      <td>{{ a.full_name }}</td>
                      <td>{{ a.product_name }}</td>
                      <td>N$ {{ a.amount }}</td>
                      <td>
                        <span class="pill {% if a.status == 'APPROVED' %}approved{% elif a.status == 'REJECTED' %}rejected{% else %}pending{% endif %}">
                          {{ a.status or 'PENDING' }}
                        </span>
                      </td>
                    </tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <div>
            <div class="card">
              <div class="card-head">
                <h3>Executive Snapshot</h3>
                <span class="muted small">Fast premium overview</span>
              </div>
              <div class="overview-list">
                <div class="overview-item">
                  <div>
                    <div><strong>Active Products</strong></div>
                    <div class="muted small">Visible to applicants</div>
                  </div>
                  <div><strong>{{ active_products or 0 }}</strong></div>
                </div>
                <div class="overview-item">
                  <div>
                    <div><strong>Unread Contacts</strong></div>
                    <div class="muted small">Customer attention needed</div>
                  </div>
                  <div><strong>{{ contacts|length if contacts is defined else 0 }}</strong></div>
                </div>
                <div class="overview-item">
                  <div>
                    <div><strong>Support Tickets</strong></div>
                    <div class="muted small">Customer support requests</div>
                  </div>
                  <div><strong>{{ support_tickets|length if support_tickets is defined else 0 }}</strong></div>
                </div>
                <div class="overview-item">
                  <div>
                    <div><strong>Portal Status</strong></div>
                    <div class="muted small">Admin live and operational</div>
                  </div>
                  <div><strong>Online</strong></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="section" id="section-applications">
        <div class="card">
          <div class="card-head">
            <h3>Loan Applications</h3>
            <input id="appSearch" type="text" placeholder="Search applications..." onkeyup="filterTable('applicationsTable', this.value)" style="max-width:280px;">
          </div>
          <div class="table-wrap">
            <table id="applicationsTable">
              <thead>
                <tr>
                  <th>Ref</th>
                  <th>Applicant</th>
                  <th>Product</th>
                  <th>Amount</th>
                  <th>Term</th>
                  <th>Status</th>
                  <th>Date</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for a in apps %}
                <tr>
                  <td><strong>{{ a.reference }}</strong></td>
                  <td>
                    <div>{{ a.full_name }}</div>
                    <div class="muted small">{{ a.email }} · {{ a.phone }}</div>
                  </td>
                  <td>{{ a.product_name }}</td>
                  <td>N$ {{ a.amount }}</td>
                  <td>{{ a.term }} months</td>
                  <td>
                    <span class="pill {% if a.status == 'APPROVED' %}approved{% elif a.status == 'REJECTED' %}rejected{% else %}pending{% endif %}">
                      {{ a.status or 'PENDING' }}
                    </span>
                  </td>
                  <td>{{ a.created_at }}</td>
                  <td>
                    <div class="actions">
                      <button class="btn sm secondary" type="button"
                        onclick='openApplicationModal({{ a.id|tojson }}, {{ a.reference|tojson }}, {{ a.full_name|tojson }}, {{ a.email|tojson }}, {{ a.phone|tojson }}, {{ a.amount|tojson }}, {{ a.status|tojson }}, {{ a.admin_note|default("", true)|tojson }})'>Open</button>
                    </div>
                  </td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="section" id="section-products">
        <div class="card">
          <div class="card-head">
            <h3>Loan Products</h3>
            <button class="btn" type="button" onclick="openProductModal()">+ Create Product</button>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Interest</th>
                  <th>Fee</th>
                  <th>Min</th>
                  <th>Max</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {% for p in loan_products %}
                <tr>
                  <td><strong>{{ p.name }}</strong></td>
                  <td>{{ p.interest_rate }}%</td>
                  <td>N$ {{ p.service_fee }}</td>
                  <td>N$ {{ p.min_amount }}</td>
                  <td>N$ {{ p.max_amount }}</td>
                  <td>
                    <span class="pill {% if p.active %}active-pill{% else %}rejected{% endif %}">
                      {{ 'ACTIVE' if p.active else 'DISABLED' }}
                    </span>
                  </td>
                  <td>
                    <div class="actions">
                      <button class="btn sm secondary" type="button"
                        onclick='openEditProduct({{ p.id|tojson }}, {{ p.name|tojson }}, {{ p.interest_rate|tojson }}, {{ p.service_fee|tojson }}, {{ p.min_amount|tojson }}, {{ p.max_amount|tojson }}, {{ p.active|tojson }})'>Edit</button>
                    </div>
                  </td>
                </tr>
                {% endfor %}
                {% if loan_products is defined and loan_products|length == 0 %}
                <tr>
                  <td colspan="7" class="muted">No loan products found yet. Click Create Product.</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="section" id="section-messages">
        <div class="card">
          <div class="card-head">
            <h3>Customer Messages</h3>
            <span class="muted small">Contacts and communication records</span>
          </div>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Email</th>
                  <th>Subject</th>
                  <th>Message</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                {% for m in contacts %}
                <tr>
                  <td>{{ m.name }}</td>
                  <td>{{ m.email }}</td>
                  <td>{{ m.subject }}</td>
                  <td>{{ m.message }}</td>
                  <td>{{ m.created_at }}</td>
                </tr>
                {% endfor %}
                {% if contacts is defined and contacts|length == 0 %}
                <tr>
                  <td colspan="5" class="muted">No customer messages found.</td>
                </tr>
                {% endif %}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <section class="section" id="section-site-config">
        <div class="card">
          <div class="card-head">
            <h3>Frontend Content</h3>
            <button class="btn success" type="button" onclick="saveForm('siteConfigForm', '/admin/site-config/save')">Save Changes</button>
          </div>
          <form id="siteConfigForm">
            <div class="form-grid">
              <div class="field"><label>Site Name</label><input name="site_name" value="{{ site_config.site_name if site_config else '' }}"></div>
              <div class="field"><label>Promo Text</label><input name="promo_text" value="{{ site_config.promo_text if site_config else '' }}"></div>
              <div class="field"><label>Hero Title</label><input name="hero_title" value="{{ site_config.hero_title if site_config else '' }}"></div>
              <div class="field"><label>Support Phone</label><input name="support_phone" value="{{ site_config.support_phone if site_config else '' }}"></div>
              <div class="field"><label>Contact Email</label><input name="email" value="{{ site_config.email if site_config else '' }}"></div>
              <div class="field"><label>Office Hours</label><input name="office_hours" value="{{ site_config.office_hours if site_config else '' }}"></div>
            </div>
            <div class="field" style="margin-top:14px;">
              <label>Hero Subtitle</label>
              <textarea name="hero_subtitle">{{ site_config.hero_subtitle if site_config else '' }}</textarea>
            </div>
            <div class="field" style="margin-top:14px;">
              <label>Footer Text</label>
              <textarea name="footer_text">{{ site_config.footer_text if site_config else '' }}</textarea>
            </div>
          </form>
        </div>
      </section>

      <section class="section" id="section-site-settings">
        <div class="card">
          <div class="card-head">
            <h3>System Rates</h3>
            <button class="btn success" type="button" onclick="saveForm('siteSettingsForm', '/admin/site-settings/save')">Save Rates</button>
          </div>
          <form id="siteSettingsForm">
            <div class="form-grid">
              <div class="field"><label>Base Interest Rate (%)</label><input type="number" step="0.01" name="interest_rate" value="{{ site_settings.interest_rate if site_settings else '' }}"></div>
              <div class="field"><label>Base Service Fee (N$)</label><input type="number" step="0.01" name="service_fee" value="{{ site_settings.service_fee if site_settings else '' }}"></div>
              <div class="field"><label>Business Loan Rate (%)</label><input type="number" step="0.01" name="business_loan_rate" value="{{ site_settings.business_loan_rate if site_settings else '' }}"></div>
              <div class="field"><label>Personal Loan Rate (%)</label><input type="number" step="0.01" name="personal_loan_rate" value="{{ site_settings.personal_loan_rate if site_settings else '' }}"></div>
              <div class="field"><label>Salary Advance Rate (%)</label><input type="number" step="0.01" name="salary_advance_rate" value="{{ site_settings.salary_advance_rate if site_settings else '' }}"></div>
            </div>
          </form>
        </div>
      </section>
    </main>
  </div>

  <div class="modal-wrap" id="productModalWrap">
    <div class="modal">
      <div class="modal-head">
        <h3 id="productModalTitle" style="margin:0;">Create Product</h3>
        <button class="btn secondary sm" type="button" onclick="closeModal('productModalWrap')">Close</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="product_id">

        <div class="form-grid">
          <div class="field">
            <label>Product Name</label>
            <input type="text" id="product_name" placeholder="e.g. Personal Loan">
          </div>
          <div class="field">
            <label>Interest Rate (%)</label>
            <input type="number" step="0.01" id="product_rate" placeholder="e.g. 15">
          </div>
          <div class="field">
            <label>Service Fee (N$)</label>
            <input type="number" step="0.01" id="product_fee" placeholder="e.g. 100">
          </div>
          <div class="field">
            <label>Minimum Amount</label>
            <input type="number" step="0.01" id="product_min" placeholder="e.g. 500">
          </div>
          <div class="field">
            <label>Maximum Amount</label>
            <input type="number" step="0.01" id="product_max" placeholder="e.g. 50000">
          </div>
          <div class="field">
            <label>Status</label>
            <select id="product_active">
              <option value="true">Active</option>
              <option value="false">Disabled</option>
            </select>
          </div>
        </div>

        <div style="display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap;margin-top:18px;">
          <button class="btn danger hidden" id="deleteProductBtn" type="button" onclick="deleteProduct()">Delete</button>
          <button class="btn success" type="button" onclick="saveProduct()">Save Product</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-wrap" id="applicationModalWrap">
    <div class="modal">
      <div class="modal-head">
        <h3 style="margin:0;">Application Review</h3>
        <button class="btn secondary sm" type="button" onclick="closeModal('applicationModalWrap')">Close</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="app_id">
        <div class="form-grid">
          <div class="field"><label>Reference</label><input id="app_ref" disabled></div>
          <div class="field"><label>Applicant Name</label><input id="app_name" disabled></div>
          <div class="field"><label>Email</label><input id="app_email" disabled></div>
          <div class="field"><label>Phone</label><input id="app_phone" disabled></div>
          <div class="field"><label>Amount</label><input id="app_amount" disabled></div>
          <div class="field">
            <label>Status</label>
            <select id="app_status">
              <option value="PENDING">Pending</option>
              <option value="APPROVED">Approved</option>
              <option value="REJECTED">Rejected</option>
            </select>
          </div>
        </div>
        <div class="field" style="margin-top:14px;">
          <label>Admin Note</label>
          <textarea id="app_admin_note"></textarea>
        </div>
        <div style="display:flex;justify-content:flex-end;margin-top:16px;">
          <button class="btn success" type="button" onclick="saveApplicationDecision()">Save Decision</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    const titles = {
      overview: ["Dashboard Overview", "Premium loan operations and platform controls."],
      applications: ["Applications", "Review and manage customer applications."],
      products: ["Loan Products", "Create, edit, and manage loan products."],
      messages: ["Messages", "Customer communication center."],
      "site-config": ["Frontend Content", "Manage homepage and public content."],
      "site-settings": ["System Rates", "Control platform loan pricing and fees."]
    };

    function toggleSidebar(){
      document.getElementById("sidebar").classList.toggle("show");
    }

    document.querySelectorAll(".nav-btn[data-section]").forEach(btn => {
      btn.addEventListener("click", () => {
        const name = btn.dataset.section;

        document.querySelectorAll(".nav-btn[data-section]").forEach(x => x.classList.remove("active"));
        btn.classList.add("active");

        document.querySelectorAll(".section").forEach(sec => sec.classList.remove("active"));
        document.getElementById("section-" + name).classList.add("active");

        document.getElementById("pageTitle").textContent = titles[name][0];
        document.getElementById("pageSubtitle").textContent = titles[name][1];

        if (window.innerWidth <= 980) {
          document.getElementById("sidebar").classList.remove("show");
        }
      });
    });

    function filterTable(tableId, searchValue){
      const q = String(searchValue || "").toLowerCase();
      const table = document.getElementById(tableId);
      if (!table) return;
      table.querySelectorAll("tbody tr").forEach(row => {
        row.style.display = row.innerText.toLowerCase().includes(q) ? "" : "none";
      });
    }

    function openModal(id){
      document.getElementById(id).classList.add("show");
    }

    function closeModal(id){
      document.getElementById(id).classList.remove("show");
    }

    function openProductModal(){
      document.getElementById("productModalTitle").textContent = "Create Product";
      document.getElementById("product_id").value = "";
      document.getElementById("product_name").value = "";
      document.getElementById("product_rate").value = "";
      document.getElementById("product_fee").value = "";
      document.getElementById("product_min").value = "";
      document.getElementById("product_max").value = "";
      document.getElementById("product_active").value = "true";
      document.getElementById("deleteProductBtn").classList.add("hidden");
      openModal("productModalWrap");
    }

    function openEditProduct(id, name, rate, fee, minAmount, maxAmount, active){
      document.getElementById("productModalTitle").textContent = "Edit Product";
      document.getElementById("product_id").value = id || "";
      document.getElementById("product_name").value = name || "";
      document.getElementById("product_rate").value = rate || "";
      document.getElementById("product_fee").value = fee || "";
      document.getElementById("product_min").value = minAmount || "";
      document.getElementById("product_max").value = maxAmount || "";
      document.getElementById("product_active").value = (String(active).toLowerCase() === "true") ? "true" : "false";
      document.getElementById("deleteProductBtn").classList.remove("hidden");
      openModal("productModalWrap");
    }

    async function saveProduct(){
      const id = document.getElementById("product_id").value.trim();
      const payload = {
        name: document.getElementById("product_name").value.trim(),
        interest_rate: parseFloat(document.getElementById("product_rate").value || 0),
        service_fee: parseFloat(document.getElementById("product_fee").value || 0),
        min_amount: parseFloat(document.getElementById("product_min").value || 0),
        max_amount: parseFloat(document.getElementById("product_max").value || 0),
        active: document.getElementById("product_active").value === "true"
      };

      if (!payload.name) {
        alert("Product name is required.");
        return;
      }

      if (payload.max_amount && payload.min_amount && payload.max_amount < payload.min_amount) {
        alert("Max amount cannot be less than min amount.");
        return;
      }

      const url = id ? `/admin/products/${id}/update` : `/admin/products/create`;

      try {
        const res = await fetch(url, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            "Accept": "application/json",
            "X-Requested-With": "XMLHttpRequest"
          },
          body: JSON.stringify(payload)
        });

        const text = await res.text();
        let data = {};
        try { data = JSON.parse(text); } catch(e) {}

        if (!res.ok || !data.success) {
          throw new Error((data && data.error) ? data.error : (text || "Save failed."));
        }

        alert(data.message || "Product saved successfully.");
        window.location.reload();
      } catch (err) {
        alert("Product save failed: " + err.message);
      }
    }

    async function deleteProduct(){
      const id = document.getElementById("product_id").value.trim();
      if (!id) {
        alert("Open an existing product first.");
        return;
      }

      if (!confirm("Delete this product?")) return;

      try {
        const res = await fetch(`/admin/products/${id}/delete`, {
          method: "POST",
          headers: {
            "Accept": "application/json",
            "X-Requested-With": "XMLHttpRequest"
          }
        });

        const text = await res.text();
        let data = {};
        try { data = JSON.parse(text); } catch(e) {}

        if (!res.ok || !data.success) {
          throw new Error((data && data.error) ? data.error : (text || "Delete failed."));
        }

        alert(data.message || "Product deleted successfully.");
        window.location.reload();
      } catch (err) {
        alert("Delete failed: " + err.message);
      }
    }

    function openApplicationModal(id, ref, name, email, phone, amount, status, note){
      document.getElementById("app_id").value = id || "";
      document.getElementById("app_ref").value = ref || "";
      document.getElementById("app_name").value = name || "";
      document.getElementById("app_email").value = email || "";
      document.getElementById("app_phone").value = phone || "";
      document.getElementById("app_amount").value = amount || "";
      document.getElementById("app_status").value = status || "PENDING";
      document.getElementById("app_admin_note").value = note || "";
      openModal("applicationModalWrap");
    }

    async function saveApplicationDecision(){
      const id = document.getElementById("app_id").value.trim();
      const payload = {
        status: document.getElementById("app_status").value,
        admin_note: document.getElementById("app_admin_note").value
      };

      try {
        const res = await fetch(`/admin/applications/${id}/status`, {
          method: "POST",
          headers: {
            "Content-Type":"application/json",
            "Accept":"application/json",
            "X-Requested-With":"XMLHttpRequest"
          },
          body: JSON.stringify(payload)
        });

        const text = await res.text();
        let data = {};
        try { data = JSON.parse(text); } catch(e) {}

        if (!res.ok || !data.success) {
          throw new Error((data && data.error) ? data.error : (text || "Update failed."));
        }

        alert(data.message || "Application updated.");
        window.location.reload();
      } catch (err) {
        alert("Application update failed: " + err.message);
      }
    }

    async function saveForm(formId, url){
      const form = document.getElementById(formId);
      const fd = new FormData(form);
      const payload = {};
      for (const [k,v] of fd.entries()) payload[k] = v;

      try {
        const res = await fetch(url, {
          method: "POST",
          headers: {
            "Content-Type":"application/json",
            "Accept":"application/json",
            "X-Requested-With":"XMLHttpRequest"
          },
          body: JSON.stringify(payload)
        });

        const text = await res.text();
        let data = {};
        try { data = JSON.parse(text); } catch(e) {}

        if (!res.ok || !data.success) {
          throw new Error((data && data.error) ? data.error : (text || "Save failed."));
        }

        alert(data.message || "Saved successfully.");
      } catch (err) {
        alert("Save failed: " + err.message);
      }
    }
  </script>
</body>
</html>
