    document.getElementById('app-ref').textContent = 'Reference: ' + (reference || '-');
    document.getElementById('app-amount').textContent = 'N$ ' + (amount || '0');
    document.getElementById('app-note').value = adminNote || '';
    document.getElementById('app-status').value = status || 'PENDING';

    const docsBox = document.getElementById('app-documents');
    const docs = Array.isArray(uploadedDocs) ? uploadedDocs : [];

    if (!docs.length) {
      docsBox.innerHTML = '<p style="text-align:center; color:var(--muted); font-size:12px; margin-top:10px;">No uploaded documents found.</p>';
    } else {
      docsBox.innerHTML = docs.map(doc => {
        const fileName = doc.original_name || doc.filename || 'Document';
        const stored = doc.filename || '';
        const fileUrl = stored ? ('/uploads/' + stored) : '#';
        const field = doc.field || 'document';

        return `
          <div style="display:flex;justify-content:space-between;align-items:center;gap:10px;padding:10px;border:1px solid var(--line);border-radius:10px;margin-bottom:10px;background:rgba(255,255,255,.03);">
