          <button class="btn secondary" type="button" onclick="closeOverlay('blacklistReasonModal')">Cancel</button>
          <button class="btn danger" type="button" onclick="confirmBlacklist()">Blacklist</button>
        </div>
      </div>
    </div>
  </div>

  <div class="modal-overlay" id="manualBlacklistModal">
    <div class="modal" style="max-width:620px;">
      <div class="modal-head">
        <h3 style="margin:0;">Manual Blacklist Entry</h3>
        <button class="btn secondary btn-sm" type="button" onclick="closeOverlay('manualBlacklistModal')">Close</button>
      </div>
      <div class="modal-body">
        <div class="form-grid">
          <div class="field">
            <label>User ID</label>
            <input type="text" id="manual_blocked_id" placeholder="Optional profile/user ID">
          </div>
          <div class="field">
            <label>Blocked Phone</label>
            <input type="text" id="manual_blocked_phone" placeholder="Optional phone">
          </div>
          <div class="field">
            <label>Blocked Email</label>
            <input type="text" id="manual_blocked_email" placeholder="Optional email">
          </div>
          <div class="field">
            <label>Reason</label>
            <input type="text" id="manual_blocked_reason" value="Blocked by admin">
          </div>
        </div>
        <div style="margin-top:16px; display:flex; justify-content:flex-end; gap:10px;">
          <button class="btn secondary" type="button" onclick="closeOverlay('manualBlacklistModal')">Cancel</button>
          <button class="btn danger" type="button" onclick="submitManualBlacklist()">Save Blacklist</button>
        </div>
      </div>
    </div>
  </div>


  <div class="modal-overlay" id="supportReplyModal">
    <div class="modal" style="max-width:700px;">
      <div class="modal-head">
        <h3 style="margin:0;">Reply to Support Ticket</h3>
        <button class="btn secondary btn-sm" type="button" onclick="closeOverlay('supportReplyModal')">Close</button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="support_reply_ticket_id">
        <input type="hidden" id="support_reply_customer_id">

        <div style="background:rgba(255,255,255,.05); padding:16px; border-radius:12px; margin-bottom:16px;">
          <div><strong id="support_reply_name"></strong></div>
          <div id="support_reply_email" style="color:var(--muted); font-size:13px; margin-top:4px;"></div>
          <hr style="border:0; border-top:1px solid var(--line); margin:12px 0;">
          <div><strong id="support_reply_subject"></strong></div>
          <div id="support_reply_message" style="margin-top:8px; color:var(--muted); line-height:1.6;"></div>
        </div>

        <div class="field">
          <label>Reply Subject</label>
          <input type="text" id="support_reply_subject_input" value="Support Reply">
        </div>

        <div class="field" style="margin-top:16px;">
          <label>Reply Message</label>
          <textarea id="support_reply_body" placeholder="Write your reply to the customer here..."></textarea>
        </div>

        <div class="field" style="margin-top:16px;">
          <label style="display:flex; align-items:center; gap:8px; text-transform:none; font-size:14px;">
            <input type="checkbox" id="support_close_ticket" checked style="width:auto;">
            Close ticket after reply
          </label>
        </div>

        <div style="margin-top:18px; text-align:right;">
          <button class="btn" type="button" onclick="sendSupportReply()">Send Reply</button>
        </div>
      </div>
    </div>
  </div>


  <div class="modal-overlay" id="customerProfileModal">
    <div class="modal" style="max-width:900px;">
      <div class="modal-head">
        <h3 style="margin:0;">Customer Account Profile</h3>
        <button class="btn secondary btn-sm" type="button" onclick="closeOverlay('customerProfileModal')">Close</button>
      </div>
      <div class="modal-body">
        <div id="customerProfileContent">
          <p style="color:var(--muted);">Loading customer profile...</p>
        </div>
      </div>
    </div>
  </div>

</body>
</html>








