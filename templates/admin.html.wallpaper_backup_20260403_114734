  function switchTab(event, tabName) {
    if (event) event.preventDefault();

    document.querySelectorAll('.section-view').forEach(el => el.classList.remove('active'));
    document.querySelectorAll('.nav-link').forEach(el => el.classList.remove('active'));

    const section = document.getElementById('view-' + tabName);
    const tab = document.getElementById('tab-' + tabName);

    if (section) section.classList.add('active');
    if (tab) tab.classList.add('active');

    const meta = TAB_META[tabName] || { title: 'Dashboard', subtitle: '' };
    const titleEl = document.getElementById('page-title');
    const subtitleEl = document.getElementById('page-subtitle');
    if (titleEl) titleEl.textContent = meta.title;
    if (subtitleEl) subtitleEl.textContent = meta.subtitle;

    const sidebar = document.getElementById('sidebar');
    if (window.innerWidth <= 900 && sidebar) sidebar.classList.remove('show');

    return false;
  }

  function toggleSidebar() {
    const sidebar = document.getElementById('sidebar');
    if (sidebar) sidebar.classList.toggle('show');
  }

  function filterTable(tableId, value) {
    const q = String(value || '').toLowerCase();
    const table = document.getElementById(tableId);
    if (!table) return;
    const rows = table.querySelectorAll('tbody tr');
    rows.forEach(row => {
      const show = row.innerText.toLowerCase().includes(q);
      row.style.display = show ? '' : 'none';
    });
  }

  function openOverlay(id) {
    const el = document.getElementById(id);
    if (el) el.classList.add('show');
  }

  function closeOverlay(id) {
    const el = document.getElementById(id);
    if (el) el.classList.remove('show');
