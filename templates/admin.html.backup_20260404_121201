<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>KATRAMONEY Admin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    :root{
      --bg:#08121d; --panel:rgba(10,18,31,.88); --card:rgba(255,255,255,.05);
      --line:rgba(255,255,255,.10); --text:#edf4ff; --muted:#9bb0ca;
      --primary:#4aa8ff; --primary2:#8cc8ff; --success:#17b26a; --danger:#f04438; --warn:#f79009;
    }
    *{box-sizing:border-box}
    body{
      margin:0;font-family:Inter,sans-serif;color:var(--text);
      background:
        linear-gradient(rgba(6,14,22,.76), rgba(6,14,22,.90)),
        url("https://images.unsplash.com/photo-1554224155-6726b3ff858f?auto=format&fit=crop&w=1600&q=80") center/cover fixed no-repeat;
    }
    .shell{display:grid;grid-template-columns:280px 1fr;min-height:100vh}
    .sidebar{background:var(--panel);border-right:1px solid var(--line);padding:18px 14px;position:sticky;top:0;height:100vh;overflow:auto}
    .brand{padding:14px;border:1px solid var(--line);border-radius:18px;background:rgba(255,255,255,.04);margin-bottom:20px}
    .brand h1{margin:0;font-size:18px}.brand p{margin:6px 0 0;color:var(--muted);font-size:12px}
    .nav-title{margin:18px 10px 8px;color:var(--muted);font-size:11px;font-weight:800;text-transform:uppercase;letter-spacing:.12em}
    .nav{display:flex;flex-direction:column;gap:8px}
    .nav button,.nav a{border:none;background:transparent;color:var(--muted);padding:13px 14px;border-radius:14px;text-align:left;font-weight:700;cursor:pointer;text-decoration:none}
    .nav button.active,.nav button:hover,.nav a:hover{background:rgba(74,168,255,.12);color:var(--text);border:1px solid rgba(74,168,255,.18)}
    .main{padding:22px}
    .topbar{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;background:rgba(9,18,31,.64);border:1px solid var(--line);border-radius:22px;padding:18px 20px;margin-bottom:18px}
    .topbar h2{margin:0}.topbar p{margin:6px 0 0;color:var(--muted);font-size:13px}
    .btn{border:none;border-radius:12px;padding:10px 14px;color:#fff;background:linear-gradient(135deg,var(--primary),var(--primary2));font-weight:800;cursor:pointer}
    .btn.secondary{background:rgba(255,255,255,.05);border:1px solid var(--line)}
    .btn.success{background:var(--success)} .btn.danger{background:var(--danger)} .btn.sm{padding:8px 12px;font-size:12px}
    .section{display:none}.section.active{display:block}
    .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:16px;margin-bottom:18px}
    .stat,.card{background:rgba(255,255,255,.05);border:1px solid var(--line);border-radius:20px;padding:18px}
    .stat small{display:block;color:var(--muted);font-size:12px;font-weight:800;text-transform:uppercase;margin-bottom:8px}
    .stat .num{font-size:28px;font-weight:900}
    .grid2{display:grid;grid-template-columns:1.2fr .95fr;gap:16px}
    .card-head{display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;margin-bottom:14px}
    .card-head h3{margin:0}
    .muted{color:var(--muted)} .small{font-size:12px}
    .table-wrap{overflow:auto;border:1px solid var(--line);border-radius:16px}
    table{width:100%;min-width:820px;border-collapse:collapse}
    th,td{padding:14px 12px;border-bottom:1px solid var(--line);text-align:left}
    th{font-size:12px;color:var(--muted);text-transform:uppercase}
    .pill{display:inline-block;padding:6px 10px;border-radius:999px;font-size:11px;font-weight:900}
    .pending{background:rgba(247,144,9,.16);color:#ffd26b}.approved{background:rgba(23,178,106,.16);color:#86e2af}
    .rejected{background:rgba(240,68,56,.16);color:#ffa6a0}.active-pill{background:rgba(74,168,255,.16);color:#9ed4ff}
    .modal-wrap{position:fixed;inset:0;background:rgba(4,10,18,.70);display:none;align-items:center;justify-content:center;padding:16px}
    .modal-wrap.show{display:flex}.modal{width:100%;max-width:760px;max-height:90vh;overflow:auto;background:#0c1828;border:1px solid var(--line);border-radius:22px}
    .modal-head,.modal-body{padding:18px}.modal-head{display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--line)}
    .form-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px}
    .field label{display:block;margin-bottom:6px;color:var(--muted);font-size:12px;font-weight:800}
    input,select,textarea{width:100%;padding:12px 14px;border-radius:12px;border:1px solid var(--line);background:rgba(255,255,255,.05);color:var(--text)}
    textarea{min-height:110px;resize:vertical}
    @media (max-width:980px){.shell{grid-template-columns:1fr}.sidebar{position:fixed;left:-110%;width:280px;transition:.25s}.sidebar.show{left:0}.grid2{grid-template-columns:1fr}}
  </style>
</head>
<body>
<div class="shell">
  <aside class="sidebar" id="sidebar">
    <div class="brand">
      <h1>KATRAMONEY Admin</h1>
      <p>Premium Banking Control Portal</p>
    </div>

    <div class="nav-title">Overview</div>
    <div class="nav">
      <button class="nav-btn active" data-section="overview">Dashboard</button>
    </div>

    <div class="nav-title">Operations</div>
    <div class="nav">
      <button class="nav-btn" data-section="applications">Applications</button>
      <button class="nav-btn" data-section="products">Loan Products</button>
      <button class="nav-btn" data-section="messages">Messages</button>
    </div>

    <div class="nav-title">Website</div>
    <div class="nav">
      <button class="nav-btn" data-section="site-config">Frontend Content</button>
      <button class="nav-btn" data-section="site-settings">System Rates</button>
      <a href="/admin/logout">Logout</a>
    </div>
  </aside>

  <main class="main">
    <div class="topbar">
      <div>
        <h2 id="pageTitle">Dashboard Overview</h2>
        <p id="pageSubtitle">Live Supabase-backed admin overview.</p>
      </div>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn secondary" type="button" onclick="toggleSidebar()">☰ Menu</button>
        <button class="btn secondary" type="button" onclick="window.location.reload()">Refresh</button>
        <button class="btn" type="button" onclick="openProductModal()">+ New Product</button>
      </div>
    </div>

    <section class="section active" id="section-overview">
      <div class="stats">
        <div class="stat"><small>Total Applications</small><div class="num">{{ apps|length if apps is defined else 0 }}</div></div>
        <div class="stat"><small>Pending Reviews</small><div class="num">{{ pending or 0 }}</div></div>
        <div class="stat"><small>Loan Products</small><div class="num">{{ loan_products|length if loan_products is defined else 0 }}</div></div>
        <div class="stat"><small>Total Requested</small><div class="num">N$ {{ "%.2f"|format(total_val or 0) }}</div></div>
      </div>

      <div class="grid2">
        <div class="card">
          <div class="card-head"><h3>Recent Applications</h3><span class="muted small">Latest customer requests</span></div>
          <div class="table-wrap">
            <table>
              <thead><tr><th>Ref</th><th>Applicant</th><th>Product</th><th>Amount</th><th>Status</th></tr></thead>
              <tbody>
                {% for a in apps[:8] %}
                <tr>
                  <td><strong>{{ a.reference }}</strong></td>
                  <td>{{ a.full_name }}</td>
                  <td>{{ a.product_name }}</td>
                  <td>N$ {{ a.amount }}</td>
                  <td><span class="pill {% if a.status == 'APPROVED' %}approved{% elif a.status == 'REJECTED' %}rejected{% else %}pending{% endif %}">{{ a.status or 'PENDING' }}</span></td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
        </div>

        <div class="card">
          <div class="card-head"><h3>Live Snapshot</h3><span class="muted small">Fresh from Supabase</span></div>
          <div style="display:grid;gap:12px">
            <div class="stat"><small>Active Products</small><div class="num">{{ active_products or 0 }}</div></div>
            <div class="stat"><small>Contacts</small><div class="num">{{ contacts|length if contacts is defined else 0 }}</div></div>
            <div class="stat"><small>Customer Messages</small><div class="num">{{ customer_messages|length if customer_messages is defined else 0 }}</div></div>
            <div class="stat"><small>Support Tickets</small><div class="num">{{ support_tickets|length if support_tickets is defined else 0 }}</div></div>
          </div>
        </div>
      </div>
    </section>

    <section class="section" id="section-applications">
      <div class="card">
        <div class="card-head"><h3>Applications</h3></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Ref</th><th>Applicant</th><th>Product</th><th>Amount</th><th>Term</th><th>Status</th></tr></thead>
            <tbody>
              {% for a in apps %}
              <tr>
                <td>{{ a.reference }}</td>
                <td>{{ a.full_name }}</td>
                <td>{{ a.product_name }}</td>
                <td>N$ {{ a.amount }}</td>
                <td>{{ a.term }} months</td>
                <td><span class="pill {% if a.status == 'APPROVED' %}approved{% elif a.status == 'REJECTED' %}rejected{% else %}pending{% endif %}">{{ a.status or 'PENDING' }}</span></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section" id="section-products">
      <div class="card">
        <div class="card-head">
          <h3>Loan Products</h3>
          <button class="btn" type="button" onclick="openProductModal()">+ Create Product</button>
        </div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Name</th><th>Interest</th><th>Fee</th><th>Min</th><th>Max</th><th>Status</th><th>Action</th></tr></thead>
            <tbody>
              {% for p in loan_products %}
              <tr>
                <td><strong>{{ p.name }}</strong></td>
                <td>{{ p.interest_rate }}%</td>
                <td>N$ {{ p.service_fee }}</td>
                <td>N$ {{ p.min_amount }}</td>
                <td>N$ {{ p.max_amount }}</td>
                <td><span class="pill {% if p.active %}active-pill{% else %}rejected{% endif %}">{{ 'ACTIVE' if p.active else 'DISABLED' }}</span></td>
                <td><button class="btn sm secondary" type="button" onclick='openEditProduct({{ p.id|tojson }}, {{ p.name|tojson }}, {{ p.interest_rate|tojson }}, {{ p.service_fee|tojson }}, {{ p.min_amount|tojson }}, {{ p.max_amount|tojson }}, {{ p.active|tojson }})'>Edit</button></td>
              </tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section" id="section-messages">
      <div class="card">
        <div class="card-head"><h3>Contacts</h3></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Name</th><th>Email</th><th>Subject</th><th>Message</th><th>Date</th></tr></thead>
            <tbody>
              {% for m in contacts %}
              <tr><td>{{ m.name }}</td><td>{{ m.email }}</td><td>{{ m.subject }}</td><td>{{ m.message }}</td><td>{{ m.created_at }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-head"><h3>Customer Messages</h3></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Subject</th><th>Message</th><th>Sender</th><th>Read</th><th>Date</th></tr></thead>
            <tbody>
              {% for m in customer_messages %}
              <tr><td>{{ m.subject }}</td><td>{{ m.message }}</td><td>{{ m.sender_role }}</td><td>{{ m.is_read }}</td><td>{{ m.created_at }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>

      <div class="card">
        <div class="card-head"><h3>Support Tickets</h3></div>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Customer</th><th>Email</th><th>Subject</th><th>Message</th><th>Status</th><th>Date</th></tr></thead>
            <tbody>
              {% for s in support_tickets %}
              <tr><td>{{ s.customer_name }}</td><td>{{ s.customer_email }}</td><td>{{ s.subject }}</td><td>{{ s.message }}</td><td>{{ s.status }}</td><td>{{ s.created_at }}</td></tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <section class="section" id="section-site-config">
      <div class="card">
        <div class="card-head"><h3>Frontend Content</h3><button class="btn success" type="button" onclick="saveForm('siteConfigForm', '/admin/site-config/save')">Save Changes</button></div>
        <form id="siteConfigForm">
          <div class="form-grid">
            <div class="field"><label>Site Name</label><input name="site_name" value="{{ site_config.site_name if site_config else '' }}"></div>
            <div class="field"><label>Promo Text</label><input name="promo_text" value="{{ site_config.promo_text if site_config else '' }}"></div>
            <div class="field"><label>Hero Title</label><input name="hero_title" value="{{ site_config.hero_title if site_config else '' }}"></div>
            <div class="field"><label>Support Phone</label><input name="support_phone" value="{{ site_config.support_phone if site_config else '' }}"></div>
            <div class="field"><label>Email</label><input name="email" value="{{ site_config.email if site_config else '' }}"></div>
            <div class="field"><label>Office Hours</label><input name="office_hours" value="{{ site_config.office_hours if site_config else '' }}"></div>
          </div>
          <div class="field" style="margin-top:14px"><label>Hero Subtitle</label><textarea name="hero_subtitle">{{ site_config.hero_subtitle if site_config else '' }}</textarea></div>
          <div class="field" style="margin-top:14px"><label>Footer Text</label><textarea name="footer_text">{{ site_config.footer_text if site_config else '' }}</textarea></div>
        </form>
      </div>
    </section>

    <section class="section" id="section-site-settings">
      <div class="card">
        <div class="card-head"><h3>System Rates</h3><button class="btn success" type="button" onclick="saveForm('siteSettingsForm', '/admin/site-settings/save')">Save Rates</button></div>
        <form id="siteSettingsForm">
          <div class="form-grid">
            <div class="field"><label>Base Interest Rate (%)</label><input type="number" step="0.01" name="interest_rate" value="{{ site_settings.interest_rate if site_settings else '' }}"></div>
            <div class="field"><label>Base Service Fee (N$)</label><input type="number" step="0.01" name="service_fee" value="{{ site_settings.service_fee if site_settings else '' }}"></div>
            <div class="field"><label>Business Loan Rate (%)</label><input type="number" step="0.01" name="business_loan_rate" value="{{ site_settings.business_loan_rate if site_settings else '' }}"></div>
            <div class="field"><label>Personal Loan Rate (%)</label><input type="number" step="0.01" name="personal_loan_rate" value="{{ site_settings.personal_loan_rate if site_settings else '' }}"></div>
            <div class="field"><label>Salary Advance Rate (%)</label><input type="number" step="0.01" name="salary_advance_rate" value="{{ site_settings.salary_advance_rate if site_settings else '' }}"></div>
          </div>
        </form>
      </div>
    </section>
  </main>
</div>

<div class="modal-wrap" id="productModalWrap">
  <div class="modal">
    <div class="modal-head">
      <h3 id="productModalTitle" style="margin:0">Create Product</h3>
      <button class="btn secondary sm" type="button" onclick="closeModal('productModalWrap')">Close</button>
    </div>
    <div class="modal-body">
      <input type="hidden" id="product_id">
      <div class="form-grid">
        <div class="field"><label>Product Name</label><input id="product_name"></div>
        <div class="field"><label>Interest Rate (%)</label><input type="number" step="0.01" id="product_rate"></div>
        <div class="field"><label>Service Fee</label><input type="number" step="0.01" id="product_fee"></div>
        <div class="field"><label>Minimum Amount</label><input type="number" step="0.01" id="product_min"></div>
        <div class="field"><label>Maximum Amount</label><input type="number" step="0.01" id="product_max"></div>
        <div class="field"><label>Status</label><select id="product_active"><option value="true">Active</option><option value="false">Disabled</option></select></div>
      </div>
      <div style="display:flex;justify-content:flex-end;gap:10px;flex-wrap:wrap;margin-top:18px">
        <button class="btn danger" id="deleteProductBtn" type="button" onclick="deleteProduct()" style="display:none">Delete</button>
        <button class="btn success" type="button" onclick="saveProduct()">Save Product</button>
      </div>
    </div>
  </div>
</div>

<script>
const titles = {
  overview:["Dashboard Overview","Live Supabase-backed admin overview."],
  applications:["Applications","Review and manage customer applications."],
  products:["Loan Products","Create, edit, and manage loan products."],
  messages:["Messages","Contacts, customer messages, and support tickets."],
  "site-config":["Frontend Content","Manage homepage and public content."],
  "site-settings":["System Rates","Control platform loan pricing and fees."]
};

function toggleSidebar(){ document.getElementById("sidebar").classList.toggle("show"); }

document.querySelectorAll(".nav-btn").forEach(btn=>{
  btn.addEventListener("click", ()=>{
    const name = btn.dataset.section;
    document.querySelectorAll(".nav-btn").forEach(x=>x.classList.remove("active"));
    btn.classList.add("active");
    document.querySelectorAll(".section").forEach(x=>x.classList.remove("active"));
    document.getElementById("section-"+name).classList.add("active");
    document.getElementById("pageTitle").textContent = titles[name][0];
    document.getElementById("pageSubtitle").textContent = titles[name][1];
  });
});

function openModal(id){ document.getElementById(id).classList.add("show"); }
function closeModal(id){ document.getElementById(id).classList.remove("show"); }

function openProductModal(){
  document.getElementById("productModalTitle").textContent = "Create Product";
  document.getElementById("product_id").value = "";
  document.getElementById("product_name").value = "";
  document.getElementById("product_rate").value = "";
  document.getElementById("product_fee").value = "";
  document.getElementById("product_min").value = "";
  document.getElementById("product_max").value = "";
  document.getElementById("product_active").value = "true";
  document.getElementById("deleteProductBtn").style.display = "none";
  openModal("productModalWrap");
}

function openEditProduct(id, name, rate, fee, minAmount, maxAmount, active){
  document.getElementById("productModalTitle").textContent = "Edit Product";
  document.getElementById("product_id").value = id || "";
  document.getElementById("product_name").value = name || "";
  document.getElementById("product_rate").value = rate || "";
  document.getElementById("product_fee").value = fee || "";
  document.getElementById("product_min").value = minAmount || "";
  document.getElementById("product_max").value = maxAmount || "";
  document.getElementById("product_active").value = String(active).toLowerCase() === "true" ? "true" : "false";
  document.getElementById("deleteProductBtn").style.display = "";
  openModal("productModalWrap");
}

async function saveProduct(){
  const id = document.getElementById("product_id").value.trim();
  const payload = {
    name: document.getElementById("product_name").value.trim(),
    interest_rate: parseFloat(document.getElementById("product_rate").value || 0),
    service_fee: parseFloat(document.getElementById("product_fee").value || 0),
    min_amount: parseFloat(document.getElementById("product_min").value || 0),
    max_amount: parseFloat(document.getElementById("product_max").value || 0),
    active: document.getElementById("product_active").value === "true"
  };

  if (!payload.name) { alert("Product name is required."); return; }

  const url = id ? `/admin/products/${id}/update` : `/admin/products/create`;

  try{
    const res = await fetch(url,{
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "Accept":"application/json",
        "X-Requested-With":"XMLHttpRequest"
      },
      body:JSON.stringify(payload)
    });
    const text = await res.text();
    let data = {};
    try { data = JSON.parse(text); } catch(e) {}
    if (!res.ok || !data.success) throw new Error(data.error || text || "Save failed");
    alert(data.message || "Product saved successfully.");
    window.location.reload();
  }catch(err){
    alert("Product save failed: " + err.message);
  }
}

async function deleteProduct(){
  const id = document.getElementById("product_id").value.trim();
  if (!id) return;

  if (!confirm("Delete this product?")) return;

  try{
    const res = await fetch(`/admin/products/${id}/delete`,{
      method:"POST",
      headers:{ "Accept":"application/json", "X-Requested-With":"XMLHttpRequest" }
    });
    const text = await res.text();
    let data = {};
    try { data = JSON.parse(text); } catch(e) {}
    if (!res.ok || !data.success) throw new Error(data.error || text || "Delete failed");
    alert(data.message || "Product deleted successfully.");
    window.location.reload();
  }catch(err){
    alert("Delete failed: " + err.message);
  }
}

async function saveForm(formId, url){
  const fd = new FormData(document.getElementById(formId));
  const payload = {};
  for (const [k,v] of fd.entries()) payload[k] = v;

  try{
    const res = await fetch(url,{
      method:"POST",
      headers:{
        "Content-Type":"application/json",
        "Accept":"application/json",
        "X-Requested-With":"XMLHttpRequest"
      },
      body:JSON.stringify(payload)
    });
    const text = await res.text();
    let data = {};
    try { data = JSON.parse(text); } catch(e) {}
    if (!res.ok || !data.success) throw new Error(data.error || text || "Save failed");
    alert(data.message || "Saved successfully.");
    window.location.reload();
  }catch(err){
    alert("Save failed: " + err.message);
  }
}
</script>
</body>
</html>
