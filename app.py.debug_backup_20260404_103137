        customer_accounts = safe_rows("customer_accounts")
        blacklist = safe_rows("blacklist", "id", True)
        contacts = safe_rows("contacts", "created_at", True)
        site_config = safe_first("site_config")
        site_settings = safe_first("site_settings")

        total_val = sum(float(a.get("amount", 0) or 0) for a in apps)
        pending = len([a for a in apps if str(a.get("status") or "").upper() == "PENDING"])
        approved = len([a for a in apps if str(a.get("status") or "").upper() == "APPROVED"])
        rejected = len([a for a in apps if str(a.get("status") or "").upper() == "REJECTED"])

        return render_template(
            "admin.html",
            apps=apps,
            loan_products=loan_products,
            support_tickets=support_tickets,
            customer_messages=customer_messages,
            loan_payments=loan_payments,
            loan_accounts=loan_accounts,
            profiles=customer_profiles,
            customer_accounts=customer_accounts,
            blacklist=blacklist,
            contacts=contacts,
            site_config=site_config,
            site_settings=site_settings,
            total_val=total_val,
            pending=pending,
            approved=approved,
            rejected=rejected
        )
    except Exception as e:
        return f"ADMIN DASHBOARD ERROR: {e}"

@app.route("/api/public-site-data", methods=["GET"])
