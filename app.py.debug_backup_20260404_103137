@app.route("/admin")
@admin_required
def admin_dashboard():
    try:
        apps = safe_rows("applications", "created_at", True)
        loan_products = safe_rows("loan_products", "id", False)
        support_tickets = safe_rows("support_tickets", "created_at", True)
