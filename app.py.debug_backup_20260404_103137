@app.route("/admin/products/create", methods=["POST"])
@admin_required
def admin_create_product():
    try:
        payload = {
            "name": to_str(request.form.get("name")),
            "description": to_str(request.form.get("description")),
            "interest_rate": to_float(request.form.get("interest_rate"), 0),
            "service_fee": to_float(request.form.get("service_fee"), 0),
            "min_amount": to_int(request.form.get("min_amount"), 0),
            "max_amount": to_int(request.form.get("max_amount"), 0),
            "active": to_bool(request.form.get("active"), True),
            "featured": to_bool(request.form.get("featured"), False),
            "icon": to_str(request.form.get("icon"), "💳"),
            "terms": parse_csv_lines(request.form.get("terms")),
            "features": parse_csv_lines(request.form.get("features"))
        }

        if not payload["name"]:
            flash("Product name is required.", "error")
            return redirect("/admin#products")

        supabase_admin.table("loan_products").insert(payload).execute()
        flash("Product created successfully.", "success")
    except Exception as e:
        print("PRODUCT CREATE ERROR:", e)
        flash(f"Failed to create product: {e}", "error")

    return redirect("/admin#products")

