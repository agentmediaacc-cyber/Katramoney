            "developer_credit": (request.form.get("developer_credit") or "").strip(),
            "homepage_notice": (request.form.get("homepage_notice") or "").strip(),
        }

        existing = supabase_admin.table("site_config").select("id").limit(1).execute().data or []
        if existing:
            supabase_admin.table("site_config").update(payload).eq("id", existing[0]["id"]).execute()
        else:
            supabase_admin.table("site_config").insert(payload).execute()

        flash("Website settings saved.", "success")
    except Exception as e:
        print("SITE CONFIG SAVE ERROR:", e)
        flash(f"Failed to save website settings: {e}", "error")

    return redirect("/admin#config")

